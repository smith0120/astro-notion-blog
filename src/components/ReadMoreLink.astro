---
import { Post } from '../lib/interfaces.ts'
import { getPostLink } from '../lib/blog-helpers.ts'

export interface Props {
  post: Post
}

const { post } = Astro.props
---

<div class="read-more-link">
  <a href={getPostLink(post.Slug)}>→記事を読む</a>
</div>

<style>
  .read-more-link {
    color: var(--fg);
    border-bottom: 1px dashed #c8c2be;
    padding-bottom: 12px;
    margin-top: 12px;
    margin-bottom: 12px;
  }
  .read-more-link a {
    color: #888084;
    font-size: 1rem;
    font-weight: 500;
    line-height: 2rem;
    text-decoration: underline;
  }
  @media (max-width: 640px) {
    .read-more-link a {
      width: 50%;
    }
  }
</style>
